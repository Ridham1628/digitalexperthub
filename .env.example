# Copy this file to .env.local and fill in your values
# Then add these same variables in Vercel Dashboard → Project → Settings → Environment Variables

# Gmail SMTP (recommended)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Google Account → Security → App Passwords → generate one
# 3. Paste the 16-character app password as SMTP_PASS (no spaces)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=digitalexperthub0@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_TO=info@digitalexperthub.com
